# Search hidden files / directories (e.g. dotfiles) by default
--hidden

# Search files in .gitignore
--no-ignore

# Using glob patterns to include/exclude files or folders
--glob=!.git/*
--glob=!node_modules
--glob=!.godot/*
--glob=!build
--glob=!builds
--glob=!.cache
--glob=!temp
--glob=!*\.map
--glob=!target
--glob=!*\.log

# Because who cares about case!?
--smart-case
